# =============================================================================
# URL Shortener — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="URL Shortener"
APP_VERSION="1.0.0"
ENVIRONMENT=development
DEBUG=true
BASE_URL=http://localhost:8000

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://shortener:shortener@localhost:5432/shortener
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# ── JWT Authentication ───────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE-THIS-TO-A-LONG-RANDOM-SECRET-KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ANONYMOUS=30
RATE_LIMIT_AUTHENTICATED=120
RATE_LIMIT_WINDOW_SECONDS=60

# ── Short Code ───────────────────────────────────────────────────────────────
SHORT_CODE_LENGTH=7
