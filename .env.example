# =============================================================================
# FastAPI Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
#
# IMPORTANT: This file is for the FastAPI backend only.
# The Next.js frontend has its own .env in frontend/ with a SEPARATE
# DATABASE_URL for Prisma/NextAuth. Do not point both services at the same
# PostgreSQL database.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="URL Shortener"
APP_VERSION="1.0.0"
ENVIRONMENT=development
DEBUG=true
BASE_URL=http://localhost:8000
# Frontend origin used when building public short-link URLs in API responses.
PUBLIC_APP_URL=http://localhost:3000

# ── Database (PostgreSQL — backend only) ───────────────────────────────────────
# Alembic owns this schema: users, urls, clicks, alembic_version.
# Local Docker Compose: postgresql+asyncpg://shortener:shortener@postgres:5432/shortener
# Production (Neon): create a SEPARATE database/branch from the frontend Prisma DB.
# Example: postgresql+asyncpg://user:pass@host/nikkalink_api?sslmode=require
DATABASE_URL=postgresql+asyncpg://shortener:shortener@localhost:5432/shortener
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ── Redis ────────────────────────────────────────────────────────────────────
# Local development only — omit on Render to auto-use Upstash credentials below.
# REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# Upstash Redis (production / Render) — converted to a TLS Redis protocol URL
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── JWT Authentication ───────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE-THIS-TO-A-LONG-RANDOM-SECRET-KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","https://nikkalink.vercel.app"]

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ANONYMOUS=30
RATE_LIMIT_AUTHENTICATED=120
RATE_LIMIT_WINDOW_SECONDS=60

# ── Short Code ───────────────────────────────────────────────────────────────
SHORT_CODE_LENGTH=7
