# =============================================================================
# NikkaLink FastAPI Backend — Environment Variables (Render)
# =============================================================================
# Copy to .env for local development. Set these in the Render dashboard for production.
# NEVER commit .env to version control.
#
# IMPORTANT: Use a SEPARATE PostgreSQL database from the Next.js Prisma frontend.
# Alembic owns: users, urls, clicks, alembic_version
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="NikkaLink API"
APP_VERSION="1.0.0"
ENVIRONMENT=production
DEBUG=false
BASE_URL=https://nikkalink.onrender.com
PUBLIC_APP_URL=https://nikkalink.vercel.app

# ── Database (PostgreSQL — backend only) ───────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx-pooler.region.aws.neon.tech/nikkalink_api?sslmode=require
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ── Redis (Upstash — omit REDIS_URL in production) ─────────────────────────
REDIS_CACHE_TTL=300
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# ── JWT Authentication ───────────────────────────────────────────────────────
JWT_SECRET_KEY=generate-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Frontend SSO (must match Vercel FRONTEND_SSO_SECRET) ─────────────────────
FRONTEND_SSO_SECRET=generate-a-long-random-secret-shared-with-vercel

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","https://nikkalink.vercel.app"]

# ── AI Summarization (optional) ────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── Background Workers ─────────────────────────────────────────────────────
ENABLE_BACKGROUND_WORKERS=true────
RATE_LIMIT_ANONYMOUS=30
RATE_LIMIT_AUTHENTICATED=120
RATE_LIMIT_WINDOW_SECONDS=60

# ── Short Code ───────────────────────────────────────────────────────────────
SHORT_CODE_LENGTH=7

# PORT is injected automatically by Render — do not set manually.
