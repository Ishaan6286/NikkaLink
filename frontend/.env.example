# =============================================================================
# NikkaLink Frontend — Environment Variables (Vercel)
# =============================================================================
# Copy to .env.local for local development.
# The frontend uses a SEPARATE Prisma/NextAuth database from the FastAPI backend.
# =============================================================================

# ── Public URLs (embedded in client bundle) ───────────────────────────────────
NEXT_PUBLIC_API_URL=https://nikkalink.onrender.com
NEXT_PUBLIC_APP_URL=https://nikkalink.vercel.app

# ── NextAuth / Google OAuth ───────────────────────────────────────────────────
# Production (Vercel): https://nikkalink.vercel.app
# Auth.js v5 reads AUTH_URL; NEXTAUTH_URL is also supported.
AUTH_URL=https://nikkalink.vercel.app
NEXTAUTH_URL=https://nikkalink.vercel.app
AUTH_SECRET=generate-a-long-random-secret
# JWT sessions by default (no Prisma required). Use database for Prisma-backed sessions:
# AUTH_SESSION_STRATEGY=database
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Google Cloud Console → Authorized redirect URI (exact match):
# https://nikkalink.vercel.app/api/auth/callback/google
# Google Cloud Console → Authorized JavaScript origins:
# https://nikkalink.vercel.app

# Shared secret with Render backend (POST /api/v1/auth/sso)
# Local dev: set the same value in backend .env
FRONTEND_SSO_SECRET=generate-a-long-random-secret-shared-with-render

# ── Database (Prisma / NextAuth — frontend only) ─────────────────────────────
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
